{
  "appId": "com.sarthaknarula.nailvana",
  "productName": "Nailvana",
  "extraResources": ["build/icons/64x64.png"],
  "files": [
    "dist-electron/**/*",
    "dist-react/**/*"
  ],
  "icon": "build/icons/icon.ico",
  "mac": {
    "target": "dmg",
    "icon": "build/icons/icon.icns",
    "extendInfo": {
      "NSCameraUsageDescription": "Nailvana uses your camera to detect hand-to-mouth habits locally."
    }
  },
  "win": {
    "target": ["portable", "msi"],
    "icon": "build/icons/icon.ico"
  },
  "linux": {
    "target": "AppImage",
    "icon": "build/icons",
    "category": "Utility"
  }
}
