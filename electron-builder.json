{
  "appId": "com.narulasarthak.catchchew", 
  "productName": "CatchChew",
  "extraResources": ["dist-electron/preload.cjs", "app.png"],
  "files": [
    "dist-electron/**/*",
    "dist-react/**/*"],
  "icon": "app.png", 
  "mac": {
