{
  "name": "nailvana",
  "private": true,
  "version": "1.0.0",
  "description": "A calm, judgment-free nail-biting tracker",
  "author": "Sarthak Narula",
  "main": "dist-electron/main.js",
  "type": "module",
  "build": {
    "appId": "com.sarthaknarula.nailvana",
    "productName": "Nailvana",
    "extraResources": [
      "build/icons/64x64.png"
    ],
    "files": [
      "dist-electron/**/*",
      "dist-react/**/*"
    ],
    "win": {
      "icon": "build/icons/icon.ico",
      "target": "nsis"
    },
    "mac": {
      "icon": "build/icons/icon.icns",
      "extendInfo": {
        "NSCameraUsageDescription": "Nailvana uses your camera to detect hand-to-mouth habits locally."
      }
    },
    "linux": {
      "icon": "build/icons",
      "target": ["AppImage"]
    }
  },
  "scripts": {
    "dev": "bun run --parallel dev:react dev:electron",
    "dev:react": "vite",
    "dev:electron": "bun run transpile:electron && cross-env NODE_ENV=development electron .",
    "copy:mediapipe": "node scripts/copy-mediapipe-assets.mjs",
    "build": "bun run copy:mediapipe && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev:landing": "vite --config vite.landing.config.ts",
    "build:landing": "vite build --config vite.landing.config.ts",
    "preview:landing": "vite preview --config vite.landing.config.ts",
    "transpile:electron": "tsc --project src/electron/tsconfig.json",
    "dist:mac": "bun run transpile:electron && bun run build && electron-builder --mac --arm64",
    "dist:win": "bun run transpile:electron && bun run build && electron-builder --win --x64",
    "dist:linux": "bun run transpile:electron && bun run build && electron-builder --linux --x64"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@mui/material": "^9.1.1",
    "npm": "^11.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
